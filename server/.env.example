# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
# Replace CLUSTER with your cluster address. DATABASE_NAME = glowco-ember (created automatically on seed)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/glowco-ember?retryWrites=true&w=majority
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3000
STUB_SERVICE_URL=http://localhost:3001
CRM_CALLBACK_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
NODE_TLS_REJECT_UNAUTHORIZED=0
DEMO_MODE=false
